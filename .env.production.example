# Copy to .env.production on the server (never commit .env.production).
# Replace DROPLET_PUBLIC_IP with your DigitalOcean Droplet IPv4 (Droplets → your server).

SPRING_PROFILES_ACTIVE=railway
DATABASE_URL=postgresql://doadmin:YOUR_DB_PASSWORD@dbaas-db-9048078-do-user-8227597-0.l.db.ondigitalocean.com:25060/defaultdb?sslmode=require
APP_JWT_SECRET=GENERATE_WITH_openssl_rand_base64_48
PORT=8080
APP_RESET_PASSWORD_BASE_URL=http://DROPLET_PUBLIC_IP:8080

# --- FCM push (required for device push; DB notifications work without it) ---
# Docker --env-file: do NOT paste multiline JSON here — it breaks. Use BASE64:
#   base64 -i firebase-service-account.json | tr -d '\n'
# APP_FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=PASTE_ONE_LINE_BASE64_HERE
# Or minify JSON to a single line: APP_FIREBASE_SERVICE_ACCOUNT_JSON={...}
# See docs/FIREBASE_VM_DOCKER.md

# --- Optional: SMTP (forgot-password email; omit or leave empty to log link only) ---
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
