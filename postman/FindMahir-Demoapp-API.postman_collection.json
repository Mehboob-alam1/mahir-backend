{
  "info": {
    "name": "FindMahir Demoapp API",
    "description": "Find Mahir API: Auth (USER, MAHIR, ADMIN), Jobs (with bidCount), WhatsApp contact (1 credit), Bids (message required; proposedPrice optional), Bookings (REACHED → IN_PROGRESS → COMPLETED), Chat (threadId), Notifications (referenceId), Users, Mahirs, Reviews.\n\n**baseUrl:** Railway default. Local: http://localhost:8080.\n\n**Setup:** Sign In or Sign Up; use Bearer {{accessToken}}. Variables: userId, mahirId, jobId, bidId, bookingId, threadId, notificationId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://mahir-backend-production.up.railway.app" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "mahirId", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "bidId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "threadId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up (Find Mahir - USER)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var json = pm.response.json();",
                "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                "  if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"USER\",\n  \"fullName\": \"Ali Khan\",\n  \"email\": \"ali@example.com\",\n  \"password\": \"secret123\",\n  \"phoneNumber\": \"+923001234567\",\n  \"dateOfBirth\": \"1995-01-20\",\n  \"location\": {\n    \"streetAddress\": \"Block 5, Clifton, Karachi\",\n    \"latitude\": 24.8,\n    \"longitude\": 67.05\n  },\n  \"accountType\": \"FREEMIUM\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Register as Find Mahir (customer). Role USER. Saves tokens to collection variables."
          }
        },
        {
          "name": "Sign Up (Become Mahir - MAHIR)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var json = pm.response.json();",
                "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                "  if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"MAHIR\",\n  \"fullName\": \"Sara Ahmed\",\n  \"email\": \"sara@example.com\",\n  \"password\": \"secret123\",\n  \"phoneNumber\": \"+923009876543\",\n  \"dateOfBirth\": \"1988-11-10\",\n  \"location\": {\n    \"streetAddress\": \"Gulberg III, Lahore\",\n    \"latitude\": 31.52,\n    \"longitude\": 74.36\n  },\n  \"accountType\": \"PREMIUM\",\n  \"serviceCategoryIds\": [1, 2],\n  \"customServiceName\": \"Custom Home Repairs\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Register as Become Mahir (professional). Role MAHIR. Use category IDs from GET /api/categories or set customServiceName. MAHIR gets 3 credits for WhatsApp contact."
          }
        },
        {
          "name": "Sign Up (ADMIN)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var json = pm.response.json();",
                "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                "  if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\",\n  \"fullName\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret123\",\n  \"phoneNumber\": \"+923000000000\",\n  \"dateOfBirth\": \"1990-01-01\",\n  \"location\": {\n    \"streetAddress\": \"Admin Office\",\n    \"latitude\": 24.8,\n    \"longitude\": 67.05\n  },\n  \"accountType\": \"FREEMIUM\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Register as ADMIN. Can authenticate like USER/MAHIR. No service categories or credits."
          }
        },
        {
          "name": "Sign In",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                "  if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/signin",
            "description": "Login (same for USER, MAHIR and ADMIN). Saves tokens to collection variables."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password",
            "description": "Request password reset. If email exists, a reset link is sent (or logged if SMTP not configured)."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"newSecret456\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password",
            "description": "Set new password using token from forgot-password email/link. Set resetToken variable from the link."
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Get new access and refresh tokens."
          }
        },
        {
          "name": "Check Session",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/auth/check-session",
            "description": "Validate token and return current user."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "description": "Logout. Client discards tokens."
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var json = pm.response.json();",
                "  if (json.id) pm.collectionVariables.set('jobId', json.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Need maths tutor, 2 hours\",\n  \"description\": \"Looking for a tutor for grade 10 maths.\",\n  \"categoryId\": 1,\n  \"location\": {\n    \"streetAddress\": \"Block 5, Karachi\",\n    \"latitude\": 24.8,\n    \"longitude\": 67.05\n  },\n  \"scheduledAt\": \"2025-03-15T14:00:00\",\n  \"budgetMin\": 800,\n  \"budgetMax\": 1000,\n  \"durationHours\": 2\n}"
            },
            "url": "{{baseUrl}}/api/jobs",
            "description": "USER posts a job (open for bids). Saves jobId. categoryId from GET /api/categories."
          }
        },
        {
          "name": "List My Jobs",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/jobs?filter=my&page=0&size=20",
            "description": "USER: list my posted jobs. Response includes bidCount per job. Add &status=OPEN or ASSIGNED etc."
          }
        },
        {
          "name": "List Open Jobs",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/jobs?page=0&size=20",
            "description": "MAHIR: list open jobs. Response includes bidCount per job. Add &categoryId=1 to filter."
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}",
            "description": "Job detail: poster, category, location, budget, status, bidCount."
          }
        },
        {
          "name": "WhatsApp Contact (1 credit)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/whatsapp-contact",
            "description": "MAHIR only. Uses 1 credit; returns posterPhoneNumber and remainingCredits. Fails if no credits (use Apply instead)."
          }
        },
        {
          "name": "Update Job",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"description\": \"Updated description\",\n  \"scheduledAt\": \"2025-03-16T10:00:00\",\n  \"budgetMin\": 900,\n  \"budgetMax\": 1200,\n  \"durationHours\": 2\n}"
            },
            "url": "{{baseUrl}}/api/jobs/{{jobId}}",
            "description": "USER can update only if status=OPEN and no accepted bid."
          }
        },
        {
          "name": "Cancel Job",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/cancel",
            "description": "USER cancels job (only if OPEN)."
          }
        }
      ]
    },
    {
      "name": "Bids",
      "item": [
        {
          "name": "Create Bid",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var json = pm.response.json();",
                "  if (json.id) pm.collectionVariables.set('bidId', json.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I can do this at 900 Rs/hr. Available weekends.\",\n  \"proposedPrice\": 1800,\n  \"proposedAt\": \"2025-03-15T14:00:00\",\n  \"estimatedDurationHours\": 2\n}"
            },
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/bids",
            "description": "MAHIR applies to a job. Message required; proposedPrice, proposedAt (ISO-8601), estimatedDurationHours optional. One bid per Mahir per job. Saves bidId."
          }
        },
        {
          "name": "List Bids for Job",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/bids?page=0&size=20",
            "description": "Poster: all bids for this job. MAHIR: only their own bid. Others get 403."
          }
        },
        {
          "name": "List My Bids",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/bids?page=0&size=20",
            "description": "MAHIR only (403 for others). List my bids. Add &status=PENDING or ACCEPTED etc."
          }
        },
        {
          "name": "Accept Bid",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.id) pm.collectionVariables.set('bookingId', json.id);",
                "  if (json.chatThreadId) pm.collectionVariables.set('threadId', json.chatThreadId);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/bids/{{bidId}}/accept",
            "description": "USER accepts one bid. Creates booking + chat thread. Rejects other bids. Saves bookingId, threadId."
          }
        },
        {
          "name": "Reject Bid",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/bids/{{bidId}}/reject",
            "description": "USER rejects a bid."
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories",
            "description": "List service categories for MAHIR signup. No auth required."
          }
        }
      ]
    },
    {
      "name": "Mahirs",
      "item": [
        {
          "name": "Search Mahirs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/mahirs?page=0&size=20",
            "description": "Search Mahirs. Add ?categoryId=1 to filter by category. Paginated; returns averageRating and reviewCount. No auth."
          }
        },
        {
          "name": "Get Mahir by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/mahirs/{{mahirId}}",
            "description": "Get one Mahir by ID with average rating and review count. No auth required."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me",
            "description": "Get current user profile (includes credits for MAHIR). Requires Bearer token."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Full Name\",\n  \"phoneNumber\": \"+923001234567\",\n  \"dateOfBirth\": \"1995-01-20\",\n  \"location\": {\n    \"streetAddress\": \"New Address\",\n    \"latitude\": 24.8,\n    \"longitude\": 67.05\n  },\n  \"accountType\": \"PREMIUM\",\n  \"serviceCategoryIds\": [1, 2],\n  \"customServiceName\": \"My Service\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\",\n  \"bio\": \"Short bio\",\n  \"password\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me",
            "description": "Update current user profile. All fields optional. MAHIR can set serviceCategoryIds and customServiceName."
          }
        },
        {
          "name": "Save FCM Token (push notifications)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fcmToken\": \"<device FCM token from Firebase SDK>\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me/fcm-token",
            "description": "Store FCM token for push notifications. App calls this after login with the device token from Firebase. When backend creates a notification, it also sends FCM push to this token. See docs/FIREBASE_PUSH_SETUP.md."
          }
        },
        {
          "name": "Create User",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Create user (legacy; for full signup use Auth > Sign Up). Requires Bearer token."
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users?page=0&size=20",
            "description": "List all users (paginated). Requires Bearer token."
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "description": "Get user by ID. Uses collection variable userId."
          }
        },
        {
          "name": "Get Public Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{userId}}/public",
            "description": "Public profile (no email/phone): fullName, avatarUrl, bio, rating, reviewCount, services. For viewing Mahir/customer before accepting bid."
          }
        },
        {
          "name": "Update User",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"updated@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "description": "Update user. Password optional."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "description": "Delete user. Only own account allowed."
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var json = pm.response.json();",
                "  if (json.id) pm.collectionVariables.set('bookingId', json.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mahirId\": {{mahirId}},\n  \"scheduledAt\": \"2025-03-01T10:00:00\",\n  \"message\": \"I need plumbing repair at my home.\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings",
            "description": "Create a booking (USER only). Set mahirId from Search Mahirs. Saves bookingId to collection."
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings?page=0&size=20",
            "description": "List my bookings. Add &status=ACCEPTED or REACHED or IN_PROGRESS or COMPLETED or CANCELLED to filter."
          }
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}",
            "description": "Get one booking. Only customer or assigned Mahir can access."
          }
        },
        {
          "name": "Update Booking Status (Reached)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/status?status=REACHED",
            "description": "USER (job poster) only. Set when Mahir has reached or agreed on chat (time/place)."
          }
        },
        {
          "name": "Update Booking Status (In Progress)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/status?status=IN_PROGRESS",
            "description": "USER (job poster) only. Set when job is working / in progress."
          }
        },
        {
          "name": "Update Booking Status (Completed)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/status?status=COMPLETED",
            "description": "USER (job poster) only. Set when job is done. Customer can then leave a review."
          }
        },
        {
          "name": "Update Booking Status (Cancel)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/status?status=CANCELLED",
            "description": "Customer or Mahir cancels the booking."
          }
        },
        {
          "name": "Cancel Booking (with reason)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel?reason=Schedule+conflict",
            "description": "Cancel booking with optional reason. Notifies the other party."
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get or Create Chat Thread for Booking",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.threadId) pm.collectionVariables.set('threadId', json.threadId);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/chat",
            "description": "Get or create chat thread for this booking. Returns threadId. Saves to collection."
          }
        },
        {
          "name": "List My Chat Threads",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/chats",
            "description": "List my chat threads. Response: threadId, otherPartyName, lastMessagePreview, lastMessageAt, unreadCount. After bid accept, thread appears for both customer and Mahir."
          }
        },
        {
          "name": "Get Chat Messages",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/chats/{{threadId}}/messages?page=0&size=50",
            "description": "Paginated message history for a thread."
          }
        },
        {
          "name": "Send Chat Message",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello, when can you start?\"\n}"
            },
            "url": "{{baseUrl}}/api/chats/{{threadId}}/messages",
            "description": "Send a message in the booking chat. Other party gets notification."
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List My Notifications",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.content && json.content.length > 0 && json.content[0].id) pm.collectionVariables.set('notificationId', json.content[0].id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications?page=0&size=20",
            "description": "Paginated list: title, body, type, referenceId (e.g. bookingId), read, createdAt. Types: BID_RECEIVED, BID_ACCEPTED, BID_REJECTED, BOOKING_CANCELLED, CHAT_MESSAGE."
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications/unread-count",
            "description": "Returns { \"count\": number }."
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/notifications/{{notificationId}}/read",
            "description": "Mark a notification as read. Uses notificationId (set by List My Notifications) or set variable manually."
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": {{bookingId}},\n  \"rating\": 5,\n  \"comment\": \"Excellent service, very professional.\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews",
            "description": "Leave a review for a completed booking (USER/customer only). One review per booking."
          }
        },
        {
          "name": "Get Reviews by Mahir ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/mahirs/{{mahirId}}/reviews?page=0&size=20",
            "description": "List reviews for a Mahir. No auth required. Paginated."
          }
        }
      ]
    }
  ]
}
